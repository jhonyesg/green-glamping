# Evolution API — configuración mínima
# Documentación: https://doc.evolution-api.com

SERVER_PORT=8080

# CAMBIA ESTA KEY — es la "API Key" que pones en Multibot > Canales
AUTHENTICATION_API_KEY=multibot-evolution-key-cambiar

# Base de datos propia de Evolution (contenedores del docker-compose)
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution123@evolution-postgres:5432/evolution

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6380

# Webhook global hacia Multibot (también se puede configurar por instancia)
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://host.docker.internal:8000/webhook/whatsapp_evolution/green-glamping
WEBHOOK_EVENTS_MESSAGES_UPSERT=true

LANGUAGE=es
